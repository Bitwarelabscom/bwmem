{
  "name": "@bitwarelabs/bwmem",
  "version": "0.2.0",
  "description": "Memory SDK for AI chatbots - facts, embeddings, semantic search, emotional capture, consolidation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./graph": {
      "import": "./dist/graph/index.js",
      "types": "./dist/graph/index.d.ts"
    },
    "./providers/openai": {
      "import": "./dist/providers/openai.js",
      "types": "./dist/providers/openai.d.ts"
    },
    "./providers/ollama": {
      "import": "./dist/providers/ollama.js",
      "types": "./dist/providers/ollama.d.ts"
    },
    "./providers/openrouter": {
      "import": "./dist/providers/openrouter.js",
      "types": "./dist/providers/openrouter.d.ts"
    }
  },
  "files": [
    "dist",
    "src/db/migrations"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "start:api": "node dist/api/server.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memory",
    "ai",
    "chatbot",
    "embeddings",
    "semantic-search",
    "facts",
    "pgvector",
    "consolidation"
  ],
  "author": "BitwareLabs",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bullmq": "^5.1.0",
    "fastify": "^5.8.4",
    "ioredis": "^5.4.1",
    "pg": "^8.11.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "neo4j-driver": "^6.0.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "neo4j-driver": "^5.0.0",
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "neo4j-driver": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
